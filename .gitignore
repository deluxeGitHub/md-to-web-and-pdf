/temp/*
/_site/temp/*
.jekyll/
_site/

# Lokal generierte PDFs – werden von der CI auf main gepusht,
# sollen aber nicht aus Versehen auf development committet werden.
# Bereits auf main getrackten PDFs sind davon nicht betroffen.
/assets/pdf/*.pdf

# Test-Fixture PDFs werden lokal generiert und nicht versioniert;
# nur die .pages-Dateien (Seitenzahl-Referenz) werden getrackt.
/test/fixtures/pdf/*.pdf
/temp/test-run/
.claude/
